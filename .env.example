# ==========================================
# Zmienne środowiskowe - Sklep ze złotem
# ==========================================
# Skopiuj do .env i uzupełnij własnymi danymi
# ==========================================

# Baza danych
DB_NAME=gold_shop
DB_USER=gold_shop_user
DB_PASSWORD=twoje_haslo_bazy
DB_HOST=localhost
DB_PREFIX=gs_

# WordPress
WP_HOME=https://twojadomena.pl
WP_SITEURL=https://twojadomena.pl/wp
WP_DEBUG=false
WP_ENVIRONMENT_TYPE=production
WP_MEMORY_LIMIT=256M

# Klucze bezpieczeństwa (wygeneruj na https://api.wordpress.org/secret-key/1.1/salt/)
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# Base.com (dawniej BaseLinker)
BASE_COM_API_TOKEN=
BASE_COM_WEBHOOK_SECRET=

# Social Media Pixele
FACEBOOK_PIXEL_ID=
TIKTOK_PIXEL_ID=
PINTEREST_TAG_ID=

# API cen złota
GOLD_API_SOURCE=nbp
GOLD_API_KEY=

# Bramki płatności
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_API_KEY=

# Wysyłka
INPOST_API_KEY=
DPD_API_KEY=
DHL_API_KEY=

# Cache
LITESPEED_KEY=

# SEO
RANK_MATH_EMAIL=
